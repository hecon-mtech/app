{
	"name": "app-hospital2",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"seed:drugs": "tsx script/seed/seed-drugs.ts",
		"seed:atc-codes": "tsx script/seed/seed-atc-codes.ts",
		"seed:hospitals": "tsx script/seed/seed-hospitals.ts",
		"seed:lavar": "tsx script/seed/seed-lavar.ts",
		"seed:operations": "tsx script/seed/seed-operations.ts",
		"seed:all": "npm run seed:hospitals && npm run seed:atc-codes && npm run seed:drugs && npm run seed:lavar && npm run seed:operations",
		"seed": "npm run seed:all",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/postcss": "^4.1.18",
		"@types/node": "^25.2.2",
		"autoprefixer": "^10.4.24",
		"csv-parse": "^6.1.0",
		"drizzle-kit": "^0.31.9",
		"iconv-lite": "^0.7.2",
		"postcss": "^8.5.6",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"tailwindcss-animate": "^1.0.7",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"chart.js": "^4.5.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"pg": "^8.18.0",
		"tailwind-merge": "^3.4.0"
	}
}
